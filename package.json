{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "tsx scripts/deploy-cloudflare.ts",
    "deploy:preview": "tsx scripts/deploy-cloudflare.ts --env preview",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply motba --local",
    "db:migrate:preview": "wrangler d1 migrations apply motba-db-preview --remote --env preview",
    "db:migrate:prod": "wrangler d1 migrations apply motba --remote",
    "data:export:supabase": "tsx scripts/export-supabase.ts",
    "data:import:d1": "tsx scripts/import-d1.ts",
    "images:audit:r2": "tsx scripts/audit-r2-images.ts",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/d3-transition": "^3.0.9",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "d3-axis": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-time": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "framer-motion": "^12.34.3",
    "jose": "^6.2.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-cloudinary": "^6.17.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-photo-album": "^3.5.1",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@tailwindcss/postcss": "^4",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-time": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^6.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.77.0"
  }
}
